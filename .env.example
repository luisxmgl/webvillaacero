# Variables de entorno del SERVIDOR (server.js / server/*) -- nunca usar el prefijo VITE_ aquí,
# eso es exclusivo de variables que Vite expone al navegador (ver src/firebase.js).
# Copia este archivo a ".env" (ya está en .gitignore) y completa con tus valores reales solo cuando
# vayas a producción. Sin este archivo, Webpay funciona igual contra el ambiente de pruebas de
# Transbank (sandbox, sin dinero real) usando las constantes públicas del propio SDK.

# Credenciales de comercio Webpay Plus (Transbank). Vacío = usa el sandbox público de integración.
WEBPAY_COMMERCE_CODE=
WEBPAY_API_KEY=
WEBPAY_ENVIRONMENT=integration
# environment: integration | production

# A dónde redirige Transbank tras el pago (debe apuntar al servidor Express, no a Vite).
WEBPAY_RETURN_URL=http://localhost:3001/api/webpay/return
# A dónde redirige el servidor al terminar, para que la SPA muestre el resultado.
FRONTEND_BASE_URL=http://localhost:5173

# Para que el servidor pueda marcar un pedido como pagado en Firebase tras un pago con Webpay.
# Genera una cuenta de servicio en: Firebase Console > Configuración del proyecto > Cuentas de
# servicio > Generar nueva clave privada. Usa UNA de las dos opciones:
#   - GOOGLE_APPLICATION_CREDENTIALS: ruta local al archivo .json descargado (no lo subas a git)
#   - FIREBASE_SERVICE_ACCOUNT_JSON: el contenido completo de ese .json en una sola línea
#     (útil en hosting donde no puedes guardar archivos, p.ej. variables de entorno de Vercel/Render)
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_DATABASE_URL=

# Puerto del servidor Express. En "npm run dev:all" se usa 3001 (separado de Vite, puerto 5173).
# En producción ("npm start") se usa 3000 por defecto, sirviendo dist/ + /api/webpay en un solo proceso.
API_PORT=3001

# Envío de correo del formulario de Contacto (server/contact.js). Sin esto configurado, el botón
# "Enviar mensaje" mostrará un error y el mensaje quedará solo en el log del servidor.
# Forma más simple y gratuita: usar tu propia cuenta de Gmail con una "contraseña de aplicación":
#   1. Activa la verificación en dos pasos en la cuenta de Gmail que va a enviar los correos.
#   2. Ve a https://myaccount.google.com/apppasswords y genera una contraseña de aplicación.
#   3. Usa esa cuenta y esa contraseña (no tu contraseña normal) abajo.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# A qué correo llegan los mensajes del formulario de contacto. Vacío = luis.inostroza1998@gmail.com.
CONTACT_EMAIL_TO=
